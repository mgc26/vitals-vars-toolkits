# Issue 35 evidence environment - example configuration
# Copy to .env and adjust if you need to override the built-in defaults:
#   cp .env.example .env
#
# NO REAL SECRETS BELONG IN THIS FILE OR IN .env.
# The values below are Medplum's PUBLISHED local-dev defaults. They are safe
# only because this stack is the local, offline EVIDENCE environment and is
# never exposed publicly (see README.md). The public Railway/Vercel sandbox
# is deployed separately with its own generated credentials.

# --- Datastore credentials (local dev defaults) ---
POSTGRES_USER=medplum
POSTGRES_PASSWORD=medplum
POSTGRES_DB=medplum
REDIS_PASSWORD=medplum

# --- Host port bindings (change only if these ports are already in use) ---
MEDPLUM_SERVER_PORT=8103
MEDPLUM_APP_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
OIE_ADMIN_PORT=8443
PAYER_SIM_PORT=8090

# --- Healthcheck wait budget for up.sh (seconds) ---
HEALTHCHECK_TIMEOUT=300
